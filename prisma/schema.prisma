generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Paste {
  id        String    @id
  title     String?
  type      String    @default("text") // "text" | "link" | "image"
  content   String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  maxViews  Int?
  views     Int       @default(0)
}
