generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Paste {
  id        String    @id
  title     String?
  type      String    @default("text") // "text" | "link" | "image"
  content   String // AES-GCM ciphertext payload (encrypted client-side)
  encrypted Boolean   @default(false)
  salt      String? // PBKDF2 salt — present only for password-protected pastes
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  maxViews  Int?
  views     Int       @default(0)
}
